{
    "name": "oauth2-oidc-pkce-client",
    "version": "0.1.10",
    "description": "Browser client for nhlis SSO's OAuth2/OIDC — authorization-code + PKCE login via popup or redirect, for any relying-party service.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/nhlis/oauth2-oidc-pkce-client.git"
    },
    "homepage": "https://github.com/nhlis/oauth2-oidc-pkce-client#readme",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./callback": {
            "types": "./dist/callback.d.ts",
            "import": "./dist/callback.js",
            "require": "./dist/callback.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run typecheck && npm run test && npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "oauth2",
        "oidc",
        "sso",
        "popup",
        "pkce"
    ],
    "devDependencies": {
        "jsdom": "^29.1.1",
        "tsup": "^8.3.0",
        "typescript": "^5.6.0",
        "vitest": "^4.1.10"
    }
}
